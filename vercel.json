{
  "cleanUrls": false,
  "trailingSlash": false,
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/documents/nebras-company-profile-2026.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/nebras-wpc-promo-video",
      "destination": "/nebras-wpc-promo-video.html",
      "permanent": true
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
